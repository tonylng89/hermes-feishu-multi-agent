# === Feishu Bot Multi-Agent Configuration ===
# Copy these lines into each agent's .env file (~/.hermes/.env or ~/.hermes/profiles/<name>/.env)

# Each agent needs its own Feishu app credentials
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_BOT_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Connection settings
FEISHU_DOMAIN=feishu
FEISHU_CONNECTION_MODE=websocket
FEISHU_DM_POLICY=open
FEISHU_GROUP_POLICY=open
GATEWAY_ALLOW_ALL_USERS=true

# === Bot Registry (必须所有 Agent 相同) ===
# Format: {"显示名": "open_id", "显示名2": "open_id2"}
# 所有 Agent 的 FEISHU_BOT_REGISTRY 值必须完全一致
FEISHU_BOT_REGISTRY={"AgentA":"ou_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa1","AgentB":"ou_bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb2"}
